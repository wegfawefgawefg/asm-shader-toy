; Standard scratch aliases. Include this when you want conventional names
; instead of assigning registers by hand.

; Normalized screen coordinates and centered coordinates.
.alias uv_x, r16
.alias uv_y, r17
.alias pos_x, r18
.alias pos_y, r19

; Primary output color.
.alias color_r, r20
.alias color_g, r21
.alias color_b, r22
.alias color_a, r23

; First sampled texture color.
.alias tex0_r, r24
.alias tex0_g, r25
.alias tex0_b, r26
.alias tex0_a, r27

; Second sampled texture color.
.alias tex1_r, r28
.alias tex1_g, r29
.alias tex1_b, r30
.alias tex1_a, r31

; General-purpose temporaries.
.alias tmp0, r32
.alias tmp1, r33
.alias tmp2, r34
.alias tmp3, r35
.alias tmp4, r36
.alias tmp5, r37
.alias tmp6, r38
.alias tmp7, r39
.alias tmp8, r40
.alias tmp9, r41
.alias tmp10, r42
.alias tmp11, r43
.alias tmp12, r44
.alias tmp13, r45
.alias tmp14, r46
.alias tmp15, r47

